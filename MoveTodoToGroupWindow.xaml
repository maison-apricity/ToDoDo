<Window x:Class="ToDoDo.MoveTodoToGroupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="그룹 이동"
        Width="360"
        Height="420"
        MinWidth="320"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground="#F4F7FF"
        FontFamily="{DynamicResource AppFontFamily}">
    <Window.Resources>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AEBAD2"/>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#263246"/>
            <Setter Property="BorderBrush" Value="#42526C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#2F4058"/><Setter TargetName="Bd" Property="BorderBrush" Value="#6D84A7"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#24324A"/>
            <Setter Property="Foreground" Value="#F4F7FF"/>
            <Setter Property="BorderBrush" Value="#556983"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#2F4058"/><Setter TargetName="Bd" Property="BorderBrush" Value="#6D84A7"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="#E5121C2B" BorderBrush="#4D5F7C" BorderThickness="1.2" CornerRadius="22" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#1A2638" BorderBrush="#445673" BorderThickness="1" CornerRadius="16" Padding="12,10">
                <Grid MouseLeftButtonDown="HeaderDragArea_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Border Width="34" Height="34" CornerRadius="10" Background="#0D1726" BorderBrush="#4F6488" BorderThickness="1" Padding="5">
                        <Image Source="{Binding HeaderIconSource}" Stretch="Uniform" RenderOptions.BitmapScalingMode="Fant" SnapsToDevicePixels="True" UseLayoutRounding="True"/>
                    </Border>
                    <TextBlock Grid.Column="2" Text="그룹 이동" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" LineStackingStrategy="BlockLineHeight" LineHeight="23" Margin="0,1,0,0"/>
                    <Button Grid.Column="3" Style="{StaticResource IconButtonStyle}" Click="CancelButton_Click">
                        <Grid Width="14" Height="14"><Rectangle Width="16" Height="1.8" Fill="#F4F7FF" RadiusX="0.9" RadiusY="0.9" RenderTransformOrigin="0.5,0.5"><Rectangle.RenderTransform><RotateTransform Angle="45"/></Rectangle.RenderTransform></Rectangle><Rectangle Width="16" Height="1.8" Fill="#F4F7FF" RadiusX="0.9" RadiusY="0.9" RenderTransformOrigin="0.5,0.5"><Rectangle.RenderTransform><RotateTransform Angle="-45"/></Rectangle.RenderTransform></Rectangle></Grid>
                    </Button>
                </Grid>
            </Border>
            <ListBox Grid.Row="2"
                     x:Name="GroupListBox"
                     ItemsSource="{Binding Groups}"
                     SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                     Background="#162338"
                     BorderBrush="#43536E"
                     BorderThickness="1"
                     Foreground="#F4F7FF"
                     HorizontalContentAlignment="Stretch"
                     Padding="0,2,0,2"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="10"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#21314B" BorderBrush="#4A5E7C" BorderThickness="1" CornerRadius="12" Padding="12">
                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Style="{StaticResource ActionButtonStyle}" Content="취소" Click="CancelButton_Click"/>
                <Button Style="{StaticResource ActionButtonStyle}" Margin="0" Content="이동" Click="MoveButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#62182435"/>
                                                    <Setter Property="BorderBrush" Value="#43536E"/>
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompletingFeedback}" Value="True">
                                                            <Setter Property="Background" Value="#7A2B476F"/>
                                                            <Setter Property="BorderBrush" Value="#9FB2FF"/>
                                                            <Setter Property="Opacity" Value="0.72"/>
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard FillBehavior="HoldEnd">
                                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                                         To="14"
                                                                                         Duration="0:0:0.18"/>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         To="0.55"
                                                                                         Duration="0:0:0.18"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.ContextMenu>
                                                <StaticResource ResourceKey="CompletedTodoContextMenu"/>
                                            </Border.ContextMenu>
                                            <Grid VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Text}"
                                                               ToolTip="{Binding Text}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               LineStackingStrategy="BlockLineHeight"
                                                               LineHeight="20"
                                                               Height="40"
                                                               ClipToBounds="True"
                                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                                        <Setter Property="Foreground" Value="#A2AECB"/>
                                                                    </DataTrigger>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsDone}" Value="True"/>
                                                                            <Condition Binding="{Binding DataContext.ShowCompletedStrikethroughSetting, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <Border Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                                            Padding="0"
                                                            CornerRadius="16"
                                                            BorderBrush="#52627E"
                                                            BorderThickness="1"
                                                            Margin="0,6,0,0">
                                                        <Grid Margin="14">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="12"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="12"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBox Grid.Row="0"
                                                                     Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                                                                     Style="{StaticResource GlassTextBoxStyle}"
                                                                     FontSize="15"
                                                                     Loaded="InlineEditTextBox_Loaded"
                                                                     KeyDown="InlineEditTextBox_KeyDown"/>
                                                            <Grid Grid.Row="2" VerticalAlignment="Center">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="8"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="8"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="8"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <ToggleButton Grid.Column="0"
                                                                              Style="{StaticResource ToggleChipButtonStyle}"
                                                                              IsChecked="{Binding EditUseDueDate, UpdateSourceTrigger=PropertyChanged}"
                                                                              Content="기한 설정"
                                                                              Margin="0"/>
                                                                <Button Grid.Column="2" Style="{StaticResource ActionButtonStyle}"
                                                                        MinWidth="0"
                                                                        Content="{Binding EditDueText}"
                                                                        Margin="0"
                                                                        IsEnabled="{Binding EditUseDueDate}"
                                                                        Click="InlineDueDateButton_Click"/>
                                                                <Button Grid.Column="4" Style="{StaticResource ActionButtonStyle}"
                                                                        MinWidth="0"
                                                                        Content="{Binding EditPriorityText}"
                                                                        Margin="0"
                                                                        Click="CycleInlinePriorityButton_Click"/>
                                                                <Button Grid.Column="6" Style="{StaticResource ActionButtonStyle}"
                                                                        MinWidth="0"
                                                                        Content="{Binding EditRepeatText}"
                                                                        Margin="0"
                                                                        Click="CycleInlineRepeatButton_Click"/>
                                                            </Grid>
                                                            <Grid Grid.Row="4" Margin="0,10,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="110"/>
                                                                    <ColumnDefinition Width="12"/>
                                                                    <ColumnDefinition Width="110"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Button Grid.Column="1" Style="{StaticResource ActionButtonStyle}" Height="38" MinWidth="0" Content="취소" Margin="0" Click="CancelInlineEditButton_Click"/>
                                                                <Button Grid.Column="3" Style="{StaticResource PrimaryActionButtonStyle}" Height="38" MinWidth="0" Content="저장" Margin="0" Click="SaveInlineEditButton_Click"/>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>

                                                    <WrapPanel Margin="0,6,0,0"
                                                              VerticalAlignment="Center"
                                                              Visibility="{Binding ShowMeta, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Border Style="{StaticResource InfoChipStyle}">
                                                            <TextBlock Text="{Binding PriorityText}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <Border Style="{StaticResource InfoChipStyle}" Visibility="{Binding HasDueDate, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding DueText}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <Border Style="{StaticResource InfoChipStyle}" Visibility="{Binding HasRepeat, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding RepeatText}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </WrapPanel>
                                                    <WrapPanel Margin="0,6,0,0"
                                                              VerticalAlignment="Center"
                                                              Visibility="{Binding IsDone, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Border Style="{StaticResource InfoChipStyle}">
                                                            <TextBlock Text="완료" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </WrapPanel>
                                                </StackPanel>

                                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                                    <Grid.Resources>
                                                        <Style x:Key="InlineActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                            <Setter Property="MinWidth" Value="78"/>
                                                            <Setter Property="Height" Value="34"/>
                                                            <Setter Property="Padding" Value="14,0"/>
                                                            <Setter Property="Margin" Value="0"/>
                                                        </Style>
                                                    </Grid.Resources>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <Button Margin="0,0,0,8" Style="{StaticResource InlineActionButtonStyle}" Content="{Binding CompleteActionText}" Click="CompleteTodoButton_Click"/>
                                                        <Button Style="{StaticResource InlineActionButtonStyle}"
                                                                Content="삭제"
                                                                Click="DeleteTodoButton_Click"
                                                                Visibility="{Binding IsDone, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <TextBlock Grid.Column="3" Text="⋮⋮" Foreground="#95A3C4" FontSize="18" Margin="0,0,0,0" VerticalAlignment="Center" Cursor="SizeAll" ToolTip="드래그로 순서를 바꿀 수 있습니다." Tag="DragHandle" PreviewMouseLeftButtonDown="TodoDragHandle_PreviewMouseLeftButtonDown" PreviewMouseMove="TodoDragHandle_PreviewMouseMove"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1"
                                        Margin="0,12,0,0"
                                        Padding="18,12"
                                        CornerRadius="16"
                                        Background="#334561"
                                        BorderBrush="#6F87AA"
                                        BorderThickness="1.1"
                                        Visibility="{Binding HasCompletedTodos, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button x:Name="CompletedFooterButton"
                                            Style="{StaticResource FooterToggleButtonStyle}"
                                            Click="ToggleCompletedDetailsButton_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="완료된 할 일"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="15.5"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"/>
                                            <Border Grid.Column="1"
                                                    Padding="12,4"
                                                    CornerRadius="10"
                                                    Background="#2E3F59"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CompletedCountText}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Grid.Column="3"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="⌄"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AreCompletedDetailsCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                <Setter Property="Text" Value="›"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Button>
                                </Border>
                            </Grid>
                        </Grid>
                </Border>
            </Grid>
            

<Grid x:Name="DeleteConfirmOverlay"
                  Grid.RowSpan="3"
                  Panel.ZIndex="50"
                  Background="#8606111D"
                  Visibility="{Binding IsDeleteOverlayVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Width="380"
                        Padding="22"
                        CornerRadius="22"
                        Background="#E31B2637"
                        BorderBrush="#647A9C"
                        BorderThickness="1.2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="그룹 삭제"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding DeleteOverlayMessage}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,18"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ActionButtonStyle}" MinWidth="88" IsCancel="True" Content="취소" Click="CancelDeleteOverlayButton_Click"/>
                            <Button x:Name="ConfirmDeleteButton" Style="{StaticResource PrimaryActionButtonStyle}" MinWidth="88" IsDefault="True" Content="삭제" Click="ConfirmDeleteOverlayButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>


            <Popup x:Name="InsertionPreviewPopup"
                   Grid.RowSpan="3"
                   Panel.ZIndex="58"
                   PlacementTarget="{Binding ElementName=RootChrome}"
                   Placement="RelativePoint"
                   AllowsTransparency="True"
                   PopupAnimation="None"
                   StaysOpen="True"
                   IsHitTestVisible="False">
                <Grid x:Name="InsertionPreviewMarker"
                      Width="240"
                      Height="6"
                      Opacity="0.72">
                    <Border Height="2"
                            VerticalAlignment="Center"
                            CornerRadius="1"
                            Background="#A7C9FF"/>
                </Grid>
            </Popup>

            <Popup x:Name="DragPreviewPopup"
                   Grid.RowSpan="3"
                   Panel.ZIndex="60"
                   PlacementTarget="{Binding ElementName=RootChrome}"
                   Placement="RelativePoint"
                   AllowsTransparency="True"
                   PopupAnimation="None"
                   StaysOpen="True"
                   IsHitTestVisible="False">
                <Border x:Name="DragPreviewCard"
                        Width="300"
                        Height="98"
                        Padding="14"
                        CornerRadius="16"
                        Background="#EE223551"
                        BorderBrush="#B7C6FF"
                        BorderThickness="1.4"
                        Opacity="0.96">
                    <StackPanel>
                        <TextBlock x:Name="DragPreviewTitleText"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="DragPreviewMetaText"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12.5"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Popup>
            <Border x:Name="SettingsPanel"
                    Grid.RowSpan="3"
                    Panel.ZIndex="40"
                    Width="320"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,54,0,0"
                    Padding="16"
                    CornerRadius="20"
                    Background="#E51B2637"
                    BorderBrush="#556983"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="620">
                    <StackPanel>
                        <TextBlock Text="설정"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="창 / 트레이"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12.5"
                                   Margin="0,0,0,8"/>
                        <Button x:Name="SettingsPinButton" Style="{StaticResource ActionButtonStyle}" Content="바탕화면 고정" Click="PinButton_Click" Margin="0,0,0,10"/>
                        <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding CloseBehaviorSettingText}" Click="ToggleCloseBehaviorSettingButton_Click" Margin="0,0,0,10"/>
                        <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding StartMinimizedSettingText}" Click="ToggleStartMinimizedSettingButton_Click" Margin="0,0,0,14"/>

                        <TextBlock Text="새 할 일 기본값"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12.5"
                                   Margin="0,0,0,8"/>
                        <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding DefaultPrioritySettingText}" Click="CycleDefaultPrioritySettingButton_Click" Margin="0,0,0,10"/>
                        <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding DefaultRepeatSettingText}" Click="CycleDefaultRepeatSettingButton_Click" Margin="0,0,0,10"/>
                        <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding DefaultDueDateSettingText}" Click="ToggleDefaultDueDateSettingButton_Click" Margin="0,0,0,14"/>

                        <TextBlock Text="완료 / 보관"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12.5"
                                   Margin="0,0,0,8"/>
                        <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding AutoArchiveSettingText}" Click="CycleAutoArchiveSettingButton_Click" Margin="0,0,0,10"/>
                        <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding CompletedStrikeThroughSettingText}" Click="ToggleCompletedStrikeThroughSettingButton_Click" Margin="0,0,0,10"/>
                        <Border Background="#162338" BorderBrush="#43536E" BorderThickness="1" CornerRadius="16" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{Binding ArchivedSummaryText}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13.5"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="보관된 항목은 목록에서 숨겨지며 여기에서 한꺼번에 복원하거나 비울 수 있습니다."
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,10"/>
                                <WrapPanel>
                                    <Button Style="{StaticResource CompactActionButtonStyle}" Content="보관 모두 복원" Click="RestoreArchivedTodosButton_Click"/>
                                    <Button Style="{StaticResource CompactActionButtonStyle}" Content="보관 모두 삭제" Margin="0" Click="DeleteArchivedTodosButton_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="백업"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12.5"
                                   Margin="0,0,0,8"/>
                        <Button Style="{StaticResource ActionButtonStyle}" Content="백업 내보내기" Click="ExportBackupButton_Click" Margin="0,0,0,10"/>
                        <Button Style="{StaticResource ActionButtonStyle}" Content="백업 가져오기" Click="ImportBackupButton_Click" Margin="0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>

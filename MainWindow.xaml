<Window x:Class="ToDoDo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:ToDoDo.Models"
        xmlns:conv="clr-namespace:ToDoDo.Converters"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        mc:Ignorable="d"
        Title="ToDoDo"
        Width="1020"
        Height="760"
        MinWidth="620"
        MinHeight="520"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        FontFamily="{DynamicResource AppFontFamily}"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseDown="Window_PreviewMouseDown"
        Closing="Window_Closing"
        SourceInitialized="Window_SourceInitialized">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <SolidColorBrush x:Key="WindowFillBrush" Color="#C00D1726"/>
        <SolidColorBrush x:Key="CardBrush" Color="#8A172336"/>
        <SolidColorBrush x:Key="CardBrushStrong" Color="#A1182638"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#465A76"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F4F7FF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AEBAD2"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7287FF"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#243452"/>
        <SolidColorBrush x:Key="InputBrush" Color="#A4162233"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#7D8BA7"/>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="#263246"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#42526C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2B3A52"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6C84A8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A4C68"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="GhostCircleButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="98"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#263246"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#42526C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30415B"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6B81A2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A4C68"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="#92A2FF"/>
        </Style>

        <Style x:Key="FilterButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12.9"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="FooterToggleButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <ContextMenu x:Key="ActiveTodoContextMenu" x:Shared="False">
            <MenuItem Header="수정" Click="RenameTodoMenuItem_Click"/>
            <MenuItem Header="복제" Click="DuplicateTodoMenuItem_Click"/>
            <Separator/>
            <MenuItem Header="맨 위로" Click="MoveTodoToTopMenuItem_Click"/>
            <MenuItem Header="맨 아래로" Click="MoveTodoToBottomMenuItem_Click"/>
            <MenuItem Header="그룹 이동..." Click="OpenMoveTodoToGroupDialogMenuItem_Click"/>
            <MenuItem Header="기한 빠르게 설정">
                <MenuItem Header="오늘" Tag="today" Click="SetTodoDueDateQuickMenuItem_Click"/>
                <MenuItem Header="내일" Tag="tomorrow" Click="SetTodoDueDateQuickMenuItem_Click"/>
                <MenuItem Header="이번 주" Tag="thisweek" Click="SetTodoDueDateQuickMenuItem_Click"/>
                <MenuItem Header="기한 제거" Tag="clear" Click="SetTodoDueDateQuickMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="반복 설정">
                <MenuItem Header="반복 없음" Tag="None" Click="SetTodoRepeatQuickMenuItem_Click"/>
                <MenuItem Header="매일" Tag="Daily" Click="SetTodoRepeatQuickMenuItem_Click"/>
                <MenuItem Header="매주" Tag="Weekly" Click="SetTodoRepeatQuickMenuItem_Click"/>
                <MenuItem Header="매월" Tag="Monthly" Click="SetTodoRepeatQuickMenuItem_Click"/>
            </MenuItem>
            <Separator/>
            <MenuItem Header="완료" Click="MarkTodoDoneMenuItem_Click"/>
            <MenuItem Header="삭제" Click="DeleteTodoMenuItem_Click"/>
        </ContextMenu>

        <ContextMenu x:Key="CompletedTodoContextMenu" x:Shared="False">
            <MenuItem Header="수정" Click="RenameTodoMenuItem_Click"/>
            <MenuItem Header="복제" Click="DuplicateTodoMenuItem_Click"/>
            <Separator/>
            <MenuItem Header="맨 위로" Click="MoveTodoToTopMenuItem_Click"/>
            <MenuItem Header="맨 아래로" Click="MoveTodoToBottomMenuItem_Click"/>
            <MenuItem Header="그룹 이동..." Click="OpenMoveTodoToGroupDialogMenuItem_Click"/>
            <MenuItem Header="기한 빠르게 설정">
                <MenuItem Header="오늘" Tag="today" Click="SetTodoDueDateQuickMenuItem_Click"/>
                <MenuItem Header="내일" Tag="tomorrow" Click="SetTodoDueDateQuickMenuItem_Click"/>
                <MenuItem Header="이번 주" Tag="thisweek" Click="SetTodoDueDateQuickMenuItem_Click"/>
                <MenuItem Header="기한 제거" Tag="clear" Click="SetTodoDueDateQuickMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="반복 설정">
                <MenuItem Header="반복 없음" Tag="None" Click="SetTodoRepeatQuickMenuItem_Click"/>
                <MenuItem Header="매일" Tag="Daily" Click="SetTodoRepeatQuickMenuItem_Click"/>
                <MenuItem Header="매주" Tag="Weekly" Click="SetTodoRepeatQuickMenuItem_Click"/>
                <MenuItem Header="매월" Tag="Monthly" Click="SetTodoRepeatQuickMenuItem_Click"/>
            </MenuItem>
            <Separator/>
            <MenuItem Header="복원" Click="RestoreTodoMenuItem_Click"/>
            <MenuItem Header="보관" Click="ArchiveTodoMenuItem_Click"/>
            <MenuItem Header="삭제" Click="DeleteTodoMenuItem_Click"/>
        </ContextMenu>

        <Style x:Key="GlassTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="#51617A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#90A1FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoChipStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Background" Value="#213145"/>
            <Setter Property="BorderBrush" Value="#45566F"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ToggleChipButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="98"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#263246"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#42526C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30415B"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6B81A2"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#27446E"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#93A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="SidebarActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="MinWidth" Value="0"/>
        </Style>

        <Style x:Key="GroupItemCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#263246"/>
            <Setter Property="BorderBrush" Value="#42526C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2E3B52"/>
                    <Setter Property="BorderBrush" Value="#7186A7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="RootChrome" Background="{StaticResource WindowFillBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1.2"
            CornerRadius="24"
            Padding="14,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="Transparent"
                  PreviewMouseLeftButtonDown="HeaderDragArea_PreviewMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="48"
                        Height="48"
                        CornerRadius="14"
                        Background="Transparent"
                        BorderBrush="#4F6488"
                        BorderThickness="1"
                        Padding="3">
                    <Image Source="{Binding HeaderIconSource}"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="Fant"
                           SnapsToDevicePixels="True"
                           UseLayoutRounding="True"/>
                </Border>

                <TextBlock Grid.Column="2"
                           Text="ToDoDo"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           LineStackingStrategy="BlockLineHeight"
                           LineHeight="28"
                           Margin="0,1,0,0"/>

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource IconButtonStyle}" Click="SidebarToggleButton_Click" ToolTip="그룹 보기/숨기기">
                        <Grid Width="16" Height="16">
                            <Rectangle Width="14" Height="1.8" Fill="#F4F7FF" RadiusX="0.9" RadiusY="0.9" VerticalAlignment="Top" Margin="0,2,0,0"/>
                            <Rectangle Width="14" Height="1.8" Fill="#F4F7FF" RadiusX="0.9" RadiusY="0.9" VerticalAlignment="Center"/>
                            <Rectangle Width="14" Height="1.8" Fill="#F4F7FF" RadiusX="0.9" RadiusY="0.9" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </Grid>
                    </Button>
                    <Button x:Name="ArchiveLauncherButton" Style="{StaticResource IconButtonStyle}" Click="OpenArchiveWindowButton_Click" ToolTip="보관함">
                        <Grid Width="18" Height="18">
                            <Path Data="M3,5 L15,5 L15,8 L3,8 Z M4,8 L14,8 L13,15 L5,15 Z" Stroke="#F4F7FF" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                            <Rectangle Width="6" Height="1.6" Fill="#F4F7FF" RadiusX="0.8" RadiusY="0.8" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0"/>
                            <Border Width="14" Height="14" Background="#6F83FF" BorderBrush="#DCE5FF" BorderThickness="1" CornerRadius="7"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-5,-5"
                                    Visibility="{Binding HasArchivedTodos, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding ArchivedCountText}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FFFFFF"/>
                            </Border>
                        </Grid>
                    </Button>
                    <Button x:Name="SettingsToggleButton" Style="{StaticResource IconButtonStyle}" Click="SettingsButton_Click" ToolTip="설정">
                        <Grid Width="18" Height="18">
                            <Path Fill="#F4F7FF" Stretch="Uniform" Data="M10.9,2.2 L11.5,3.8 C11.9,4.0 12.3,4.2 12.7,4.5 L14.3,4.0 L15.5,5.2 L15.0,6.8 C15.3,7.2 15.5,7.6 15.7,8.0 L17.3,8.6 L17.3,10.3 L15.7,10.8 C15.5,11.3 15.3,11.7 15.0,12.1 L15.5,13.7 L14.3,14.9 L12.7,14.4 C12.3,14.7 11.9,14.9 11.5,15.1 L10.9,16.7 L9.2,16.7 L8.6,15.1 C8.1,14.9 7.7,14.7 7.3,14.4 L5.7,14.9 L4.5,13.7 L5.0,12.1 C4.7,11.7 4.5,11.3 4.3,10.8 L2.7,10.3 L2.7,8.6 L4.3,8.0 C4.5,7.6 4.7,7.2 5.0,6.8 L4.5,5.2 L5.7,4.0 L7.3,4.5 C7.7,4.2 8.1,4.0 8.6,3.8 L9.2,2.2 Z M10.05,6.7 A2.75,2.75 0 1 0 10.05,12.2 A2.75,2.75 0 1 0 10.05,6.7 Z"/>
                        </Grid>
                    </Button>
                    <Button x:Name="HeaderPinButton" Style="{StaticResource IconButtonStyle}" Click="PinButton_Click" ToolTip="바탕화면 고정">
                        <Grid Width="18" Height="18" SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <Image Source="assets/PinButton.png"
                                   Width="18"
                                   Height="18"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"
                                   RenderOptions.BitmapScalingMode="Fant"
                                   RenderTransformOrigin="0.5,0.42">
                                <Image.RenderTransform>
                                    <RotateTransform x:Name="HeaderPinIconRotate" Angle="0"/>
                                </Image.RenderTransform>
                            </Image>
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" Click="MinimizeButton_Click" ToolTip="최소화">
                        <Rectangle Width="12" Height="1.8" RadiusX="0.9" RadiusY="0.9" Fill="#F4F7FF"/>
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" Margin="0" Click="CloseButton_Click" ToolTip="닫기">
                        <Grid Width="14" Height="14">
                            <Rectangle Width="16" Height="1.8" RadiusX="0.9" RadiusY="0.9" Fill="#F4F7FF" RenderTransformOrigin="0.5,0.5">
                                <Rectangle.RenderTransform><RotateTransform Angle="45"/></Rectangle.RenderTransform>
                            </Rectangle>
                            <Rectangle Width="16" Height="1.8" RadiusX="0.9" RadiusY="0.9" Fill="#F4F7FF" RenderTransformOrigin="0.5,0.5">
                                <Rectangle.RenderTransform><RotateTransform Angle="-45"/></Rectangle.RenderTransform>
                            </Rectangle>
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
                    <ColumnDefinition x:Name="SidebarSpacerColumn" Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="SidebarCard"
                        Grid.Column="0"
                        Background="{StaticResource CardBrushStrong}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="16"
                        Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="그룹"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   LineStackingStrategy="BlockLineHeight"
                                   LineHeight="30"
                                   Margin="0,2,0,14"/>

                        <ListBox Grid.Row="1" x:Name="GroupListBox"
                                     ItemsSource="{Binding Groups}"
                                     SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     Margin="0,4,0,0"
                                     Padding="0,2,0,2"
                                     HorizontalContentAlignment="Stretch"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     AllowDrop="True"
                                     DragOver="GroupListBox_DragOver"
                                     Drop="GroupListBox_Drop"
                                     KeyDown="GroupListBox_KeyDown">
                                
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="SelectionBorder"
                                                            Background="Transparent"
                                                            CornerRadius="18">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="SelectionBorder" Property="Background" Value="#1D2E55"/>
                                                            <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="#8EA0FF"/>
                                                            <Setter TargetName="SelectionBorder" Property="BorderThickness" Value="1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:TaskGroup}">
                                        <Border Background="Transparent"
                                                MouseLeftButtonDown="GroupItem_MouseLeftButtonDown"
                                                PreviewMouseLeftButtonDown="GroupItem_PreviewMouseLeftButtonDown"
                                                PreviewMouseMove="GroupItem_PreviewMouseMove">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="이름 바꾸기" Click="RenameGroupMenuItem_Click"/>
                                                    <MenuItem Header="삭제" Click="DeleteGroupMenuItem_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border Style="{StaticResource GroupItemCardStyle}">
                                                <Grid VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="38"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="34"
                                                            Height="34"
                                                            CornerRadius="12"
                                                            Background="#34435C"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center">
                                                        <Grid>
                                                            <Ellipse Width="7" Height="7" Fill="#DCE6FF" Margin="8,8,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                                            <Ellipse Width="7" Height="7" Fill="#DCE6FF" Margin="8,0,0,8" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                                                            <Rectangle Width="11" Height="2.4" Fill="#DCE6FF" RadiusX="1.2" RadiusY="1.2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,8,0"/>

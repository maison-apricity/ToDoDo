<Window x:Class="ToDoDo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ToDoDo"
        Width="860"
        Height="600"
        MinWidth="640"
        MinHeight="420"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        ContextMenuOpening="MainWindow_ContextMenuOpening"
        FontFamily="{DynamicResource AppFontFamily}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#09111E"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#202A3B"/>
        <SolidColorBrush x:Key="SurfaceSoftBrush" Color="#162030"/>
        <SolidColorBrush x:Key="SurfaceStrongBrush" Color="#313B4A"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#2EFFFFFF"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F5F7FB"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#BAC5D6"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8793A6"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#6F85FF"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#1D2A58"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#63CBA7"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F8BF77"/>

        <DropShadowEffect x:Key="RootShadow"
                          BlurRadius="18"
                          ShadowDepth="0"
                          Color="#AA000000"
                          Opacity="0.24"/>

        <Storyboard x:Key="ButtonHoverIn">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.12"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.12"/>
        </Storyboard>
        <Storyboard x:Key="ButtonHoverOut">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.16"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.16"/>
        </Storyboard>
        <Storyboard x:Key="ButtonPressIn">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.98" Duration="0:0:0.06"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.98" Duration="0:0:0.06"/>
        </Storyboard>
        <Storyboard x:Key="ButtonPressOut">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.08"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.08"/>
        </Storyboard>

        <Style x:Key="AnimatedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="Background" Value="#12FFFFFF"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1BFFFFFF"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource BorderBrushStrong}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#26FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Mouse.MouseEnter">
                    <BeginStoryboard Storyboard="{StaticResource ButtonHoverIn}"/>
                </EventTrigger>
                <EventTrigger RoutedEvent="Mouse.MouseLeave">
                    <BeginStoryboard Storyboard="{StaticResource ButtonHoverOut}"/>
                </EventTrigger>
                <EventTrigger RoutedEvent="ButtonBase.PreviewMouseLeftButtonDown">
                    <BeginStoryboard Storyboard="{StaticResource ButtonPressIn}"/>
                </EventTrigger>
                <EventTrigger RoutedEvent="ButtonBase.PreviewMouseLeftButtonUp">
                    <BeginStoryboard Storyboard="{StaticResource ButtonPressOut}"/>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource AnimatedButtonStyle}">
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource AnimatedButtonStyle}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource AnimatedButtonStyle}">
            <Setter Property="Background" Value="#6F85FF"/>
            <Setter Property="BorderBrush" Value="#7E93FF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="MinWidth" Value="94"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                CornerRadius="16"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#7D92FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#5D73EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChipButtonStyle" TargetType="Button" BasedOn="{StaticResource AnimatedButtonStyle}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Background" Value="#0FFFFFFF"/>
        </Style>

        <Style x:Key="ComposerComboStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="GlassTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#7085FF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#6D86FF"/>
                                <Setter TargetName="Chrome" Property="Background" Value="#16FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="SidebarListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="#0BFFFFFF"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="12">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#172544"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#7388FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.ContextMenu>
        <ContextMenu x:Name="MainContextMenu"
                     Background="#233042"
                     Foreground="{StaticResource PrimaryTextBrush}"
                     BorderBrush="#2AFFFFFF"
                     BorderThickness="1">
            <MenuItem Header="빠른 추가 열기" Click="QuickAddContextMenu_Click"/>
            <Separator/>
            <MenuItem Header="필터">
                <MenuItem x:Name="ContextFilterAllMenuItem" Header="전체" Click="ContextFilterAllMenuItem_Click" IsCheckable="True"/>
                <MenuItem x:Name="ContextFilterTodayMenuItem" Header="오늘" Click="ContextFilterTodayMenuItem_Click" IsCheckable="True"/>
                <MenuItem x:Name="ContextFilterWeekMenuItem" Header="이번 주" Click="ContextFilterWeekMenuItem_Click" IsCheckable="True"/>
                <MenuItem x:Name="ContextFilterLaterMenuItem" Header="나중에" Click="ContextFilterLaterMenuItem_Click" IsCheckable="True"/>
            </MenuItem>
            <MenuItem x:Name="ContextAutoCollapseMenuItem" Header="완료 항목 자동 접기" Click="ContextAutoCollapseMenuItem_Click" IsCheckable="True"/>
            <MenuItem x:Name="ContextSidebarMenuItem" Header="사이드바 표시" Click="ContextSidebarMenuItem_Click" IsCheckable="True"/>
            <MenuItem x:Name="ContextHotkeyMenuItem" Header="Ctrl+Alt+T 빠른 추가" Click="ContextHotkeyMenuItem_Click" IsCheckable="True"/>
            <MenuItem x:Name="ContextBottomMostMenuItem" Header="바탕화면에 다시 고정" Click="ContextBottomMostMenuItem_Click"/>
            <MenuItem Header="설정 열기" Click="SettingsButton_Click"/>
            <Separator/>
            <MenuItem Header="백업 내보내기" Click="ExportButton_Click"/>
            <MenuItem Header="백업 가져오기" Click="ImportButton_Click"/>
        </ContextMenu>
    </Window.ContextMenu>

    <Border x:Name="RootCard"
            Background="{StaticResource WindowBackgroundBrush}"
            BorderBrush="#2AFFFFFF"
            BorderThickness="1"
            CornerRadius="26"
            Effect="{StaticResource RootShadow}">
        <Grid x:Name="Outer" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar" Grid.Row="0" Margin="18,16,18,8" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="46" Height="46" CornerRadius="16" Background="#86C9FF" VerticalAlignment="Center">
                        <Grid>
                            <Path Fill="#2B3450" Data="M10,11 A3,3 0 1 1 10,17 A3,3 0 1 1 10,11 M10,21 A3,3 0 1 1 10,27 A3,3 0 1 1 10,21 M18,11 H30 A2,2 0 0 1 30,17 H18 Z M18,21 H26 A2,2 0 0 1 26,27 H18 Z" Stretch="Uniform" Width="26" Height="26"/>
                        </Grid>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="ToDoDo" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="바탕화면에 고정되는 개인 작업 보드" FontSize="12.5" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding SummaryText}" FontSize="12" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Click="ToggleSidebarButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="목록 표시/숨기기" Margin="0,0,8,0">
                        <Path Stroke="White" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M8,11 H24 M8,17 H24 M8,23 H24" Width="18" Height="18" Stretch="Uniform"/>
                    </Button>
                    <Button Click="SettingsButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="설정" Margin="0,0,8,0">
                        <Path Stroke="White" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M16,6.5 L18,8.2 L20.8,7.6 L22,10.2 L24.9,10.8 L24.9,13.8 L27,15.7 L25.5,18.1 L26,21 L23.3,22.1 L22.2,24.9 L19.2,24.5 L17,26.3 L14.7,24.5 L11.8,24.9 L10.6,22.1 L8,21 L8.5,18.1 L7,15.7 L9.1,13.8 L9.1,10.8 L12,10.2 L13.2,7.6 L16,8.2 Z M17,12.5 A4.5,4.5 0 1 1 17,21.5 A4.5,4.5 0 1 1 17,12.5" Width="18" Height="18" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="LockButton" Click="LockButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="위치 고정" Margin="0,0,8,0">
                        <Path Fill="White" Data="M20,5 L28,13 L24.8,16.2 L22.7,14.1 L18.5,18.3 L20.6,20.4 L18.4,22.6 L16.3,20.5 L10.9,25.9 L9.1,24.1 L14.5,18.7 L12.4,16.6 L14.6,14.4 L16.7,16.5 L20.9,12.3 L18.8,10.2 Z" Width="18" Height="18" Stretch="Uniform"/>
                    </Button>
                    <Button Click="HideButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="숨기기" Margin="0,0,8,0">
                        <Path Stroke="White" StrokeThickness="1.9" StrokeStartLineCap="Round" Data="M9,16 H25" Width="18" Height="18" Stretch="Uniform"/>
                    </Button>
                    <Button Click="ExitButton_Click" Style="{StaticResource IconButtonStyle}" ToolTip="종료">
                        <Path Stroke="White" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M10,10 L24,24 M24,10 L10,24" Width="18" Height="18" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="18,0,18,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="#0FFFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="5">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="FilterAllButton" Click="FilterAllButton_Click" Style="{StaticResource ToolbarButtonStyle}" Content="전체" Margin="0,0,6,0"/>
                        <Button x:Name="FilterTodayButton" Click="FilterTodayButton_Click" Style="{StaticResource ToolbarButtonStyle}" Content="오늘" Margin="0,0,6,0"/>
                        <Button x:Name="FilterThisWeekButton" Click="FilterThisWeekButton_Click" Style="{StaticResource ToolbarButtonStyle}" Content="이번 주" Margin="0,0,6,0"/>
                        <Button x:Name="FilterLaterButton" Click="FilterLaterButton_Click" Style="{StaticResource ToolbarButtonStyle}" Content="나중에"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Column="1" Text="우클릭 메뉴와 설정 패널에서 세부 옵션을 바꿀 수 있습니다" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="18,0,0,0"/>
            </Grid>

            <Grid Grid.Row="2" Margin="18,0,18,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="SidebarPanel"
                        Grid.Column="0"
                        Background="#15202F"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="목록" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"/>
                            <TextBlock Text="그룹" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,6,0,0"/>
                            <TextBlock Text="클릭으로 선택하고, 다시 누르면 이름을 바꿀 수 있습니다" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <ListBox x:Name="GroupListBox"
                                 Grid.Row="1"
                                 ItemsSource="{Binding Groups}"
                                 SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                                 ItemContainerStyle="{StaticResource SidebarListBoxItemStyle}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Margin="0,18,0,18"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Width="30" Height="30" CornerRadius="10" Background="#1AFFFFFF" VerticalAlignment="Center">
                                            <Grid>
                                                <Path Fill="#DCE4F3" Data="M9,8 A3,3 0 1 1 9,14 A3,3 0 1 1 9,8 M9,18 A3,3 0 1 1 9,24 A3,3 0 1 1 9,18 M16,8 H25 A2,2 0 0 1 25,14 H16 Z M16,18 H23 A2,2 0 0 1 23,24 H16 Z" Stretch="Uniform" Width="18" Height="18"/>
                                            </Grid>
                                        </Border>

                                        <Grid Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" PreviewMouseLeftButtonDown="GroupNameDisplay_PreviewMouseLeftButtonDown">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="10,6"
                                                     FontSize="14"
                                                     Loaded="GroupRenameTextBox_Loaded"
                                                     LostFocus="GroupRenameTextBox_LostFocus"
                                                     KeyDown="GroupRenameTextBox_KeyDown">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource GlassTextBoxStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Setter Property="Padding" Value="10,6"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="2">
                            <Button Content="새 목록 추가" Click="AddGroupButton_Click" Style="{StaticResource AnimatedButtonStyle}" Height="42" Margin="0,0,0,8"/>
                            <Button Content="선택한 목록 삭제" Click="DeleteGroupButton_Click" Style="{StaticResource AnimatedButtonStyle}" Height="42"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Background="#15202F"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="선택한 목록" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBox x:Name="GroupNameTextBox"
                                         Style="{StaticResource GlassTextBoxStyle}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="30"
                                         FontWeight="SemiBold"
                                         Padding="0,4,0,4"
                                         Margin="0,4,0,0"
                                         LostFocus="GroupNameTextBox_LostFocus"
                                         KeyDown="GroupNameTextBox_KeyDown"/>
                                <TextBlock Text="오늘 해야 할 일부터 차분하게 정리해 보세요" FontSize="12.5" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <Button x:Name="CompletedFoldToggleButton" Click="CompletedFoldToggleButton_Click" Style="{StaticResource AnimatedButtonStyle}" Content="완료 자동 접기" Height="38" Margin="0,0,8,0"/>
                                <Button Click="RePinButton_Click" Style="{StaticResource AnimatedButtonStyle}" Content="다시 고정" Height="38"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,18,0,18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ListBox x:Name="ActiveTodoListBox"
                                         ItemsSource="{Binding VisibleActiveTodoItems}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         AllowDrop="True"
                                         PreviewMouseLeftButtonDown="ActiveTodoListBox_PreviewMouseLeftButtonDown"
                                         MouseMove="ActiveTodoListBox_MouseMove"
                                         DragOver="ActiveTodoListBox_DragOver"
                                         Drop="ActiveTodoListBox_Drop"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,12"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#152331" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Padding="14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox IsChecked="{Binding IsDone}" VerticalAlignment="Top" Margin="2,4,12,0" Width="20" Height="20"/>

                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Text}" FontSize="16" FontWeight="Medium" Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap"/>
                                                        <WrapPanel Margin="0,12,0,0" ItemHeight="30" ItemWidth="Auto">
                                                            <Button Content="{Binding DueDateLabel}" Tag="{Binding}" Click="DueDateButton_Click" Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                                            <Button Content="{Binding RepeatLabel}" Tag="{Binding}" Click="RepeatButton_Click" Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                                            <Button Content="{Binding PriorityLabel}" Tag="{Binding}" Click="PriorityButton_Click" Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                                        </WrapPanel>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                                        <Button Content="↑" Tag="{Binding}" Click="MoveUpButton_Click" Style="{StaticResource IconButtonStyle}" Width="34" Height="34" Margin="0,0,6,0"/>
                                                        <Button Content="↓" Tag="{Binding}" Click="MoveDownButton_Click" Style="{StaticResource IconButtonStyle}" Width="34" Height="34" Margin="0,0,6,0"/>
                                                        <Button Tag="{Binding}" Click="DeleteTodo_Click" Style="{StaticResource IconButtonStyle}" Width="34" Height="34">
                                                            <Path Stroke="White" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M10,10 L24,24 M24,10 L10,24" Width="16" Height="16" Stretch="Uniform"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Grid.Row="1"
                                           Text="아직 등록된 작업이 없습니다. 아래 입력 영역에서 바로 추가해 보세요."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12.5"
                                           Margin="4,4,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=ActiveTodoListBox, Path=Items.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <Expander x:Name="CompletedExpander" Grid.Row="1" Margin="0,8,0,0" Foreground="{StaticResource PrimaryTextBrush}" Header="{Binding CompletedHeaderText}" IsExpanded="False">
                                <ListBox x:Name="CompletedTodoListBox"
                                         ItemsSource="{Binding VisibleCompletedTodoItems}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Margin="0,10,0,0">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,10"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#101925" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="14" Opacity="0.88">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox IsChecked="{Binding IsDone}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Text}" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" TextDecorations="Strikethrough" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding CompletedAt, StringFormat=완료: {0:yyyy.MM.dd HH:mm}}" FontSize="11.5" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Expander>
                        </Grid>

                        <Border Grid.Row="2" Background="#101926" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NewTodoTextBox"
                                         Grid.Column="0"
                                         Style="{StaticResource GlassTextBoxStyle}"
                                         Margin="0,0,12,0"
                                         VerticalContentAlignment="Center"
                                         Text=""
                                         KeyDown="NewTodoTextBox_KeyDown"
                                         ToolTip="할 일을 입력하세요"/>
                                <DatePicker x:Name="NewTodoDatePicker"
                                            Grid.Column="1"
                                            Style="{StaticResource GlassDatePickerStyle}"
                                            Margin="0,0,12,0"
                                            SelectedDateFormat="Short"
                                            ToolTip="마감일"/>
                                <ComboBox x:Name="NewTodoPriorityComboBox"
                                          Grid.Column="2"
                                          Style="{StaticResource ComposerComboStyle}"
                                          Margin="0,0,12,0"
                                          SelectedIndex="1">
                                    <ComboBoxItem Content="낮음" Tag="Low"/>
                                    <ComboBoxItem Content="보통" Tag="Medium"/>
                                    <ComboBoxItem Content="높음" Tag="High"/>
                                </ComboBox>
                                <ComboBox x:Name="NewTodoRepeatComboBox"
                                          Grid.Column="3"
                                          Style="{StaticResource ComposerComboStyle}"
                                          Margin="0,0,12,0"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="반복 없음" Tag="None"/>
                                    <ComboBoxItem Content="매일" Tag="Daily"/>
                                    <ComboBoxItem Content="매주" Tag="Weekly"/>
                                    <ComboBoxItem Content="매월" Tag="Monthly"/>
                                </ComboBox>
                                <Button Grid.Column="4" Content="추가" Click="AddTodo_Click" Style="{StaticResource AccentButtonStyle}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="SettingsPanel"
                        Grid.ColumnSpan="3"
                        Width="300"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Background="#15202F"
                        BorderBrush="{StaticResource BorderBrushStrong}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="18"
                        Margin="0,0,0,0"
                        Visibility="Collapsed"
                        Panel.ZIndex="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="설정" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                                <TextBlock Text="보드 동작과 백업 옵션을 한곳에서 관리합니다" FontSize="12.5" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button Grid.Column="1" Click="SettingsCloseButton_Click" Style="{StaticResource IconButtonStyle}" Width="34" Height="34" ToolTip="닫기">
                                <Path Stroke="White" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M10,10 L24,24 M24,10 L10,24" Width="16" Height="16" Stretch="Uniform"/>
                            </Button>
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="0,18,0,0">
                            <CheckBox x:Name="BottomMostCheckBox" Content="바탕화면에 고정 유지" Click="BottomMostCheckBox_Click" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13.5" Margin="0,0,0,14"/>
                            <CheckBox x:Name="SidebarVisibleCheckBox" Content="사이드바 표시" Click="SidebarVisibilityCheckBox_Click" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13.5" Margin="0,0,0,14"/>
                            <CheckBox x:Name="QuickAddHotkeyCheckBox" Content="Ctrl+Alt+T 빠른 추가" Click="QuickAddHotkeyCheckBox_Click" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13.5" Margin="0,0,0,14"/>
                            <CheckBox x:Name="AutoCollapseCheckBox" Content="완료 항목 자동 접기" Click="AutoCollapseCheckBox_Click" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13.5" Margin="0,0,0,18"/>

                            <TextBlock Text="데이터" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,10"/>
                            <Button Content="백업 내보내기" Click="ExportButton_Click" Style="{StaticResource AnimatedButtonStyle}" Height="42" Margin="0,0,0,10"/>
                            <Button Content="백업 가져오기" Click="ImportButton_Click" Style="{StaticResource AnimatedButtonStyle}" Height="42" Margin="0,0,0,10"/>
                            <Button Content="트레이에서 다시 표시" Click="RestoreFromSettingsButton_Click" Style="{StaticResource AnimatedButtonStyle}" Height="42"/>
                        </StackPanel>

                        <Border Grid.Row="2" Background="#0DFFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,18,0,0">
                            <TextBlock Text="저장은 자동으로 진행되며, 재시작 후에도 목록과 설정이 유지됩니다." Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>

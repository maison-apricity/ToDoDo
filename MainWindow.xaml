<Window x:Class="ToDoDo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:ToDoDo.Models"
        xmlns:conv="clr-namespace:ToDoDo.Converters"
        mc:Ignorable="d"
        Title="ToDoDo"
        Width="1020"
        Height="760"
        MinWidth="620"
        MinHeight="520"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        FontFamily="{DynamicResource AppFontFamily}"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseDown="Window_PreviewMouseDown"
        Closing="Window_Closing"
        SourceInitialized="Window_SourceInitialized">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <SolidColorBrush x:Key="WindowFillBrush" Color="#C00D1726"/>
        <SolidColorBrush x:Key="CardBrush" Color="#8A172336"/>
        <SolidColorBrush x:Key="CardBrushStrong" Color="#A1182638"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#465A76"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F4F7FF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AEBAD2"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7287FF"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#243452"/>
        <SolidColorBrush x:Key="InputBrush" Color="#A4162233"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#7D8BA7"/>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="#263246"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#42526C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30415B"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7387A7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A4C68"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="GhostCircleButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="98"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="#263246"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#42526C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30415B"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6B81A2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A4C68"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="#92A2FF"/>
        </Style>

        <Style x:Key="FilterButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12.9"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="GlassTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="#51617A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#90A1FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoChipStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Background" Value="#213145"/>
            <Setter Property="BorderBrush" Value="#45566F"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ToggleChipButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="98"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#263246"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#42526C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30415B"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6B81A2"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#27446E"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#93A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="SidebarActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="MinWidth" Value="0"/>
        </Style>

        <Style x:Key="GroupItemCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#263246"/>
            <Setter Property="BorderBrush" Value="#42526C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2E3B52"/>
                    <Setter Property="BorderBrush" Value="#7186A7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="RootChrome" Background="{StaticResource WindowFillBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1.2"
            CornerRadius="24"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="Transparent"
                  PreviewMouseLeftButtonDown="HeaderDragArea_PreviewMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="48"
                        Height="48"
                        CornerRadius="16"
                        Background="#7BC0FF">
                    <Grid>
                        <Ellipse Width="8" Height="8" Fill="#122034" Margin="10,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Ellipse Width="8" Height="8" Fill="#122034" Margin="10,0,0,10" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                        <Rectangle Width="14" Height="3" Fill="#122034" RadiusX="1.5" RadiusY="1.5" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,11,10,0"/>
                        <Rectangle Width="14" Height="3" Fill="#122034" RadiusX="1.5" RadiusY="1.5" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,11"/>
                    </Grid>
                </Border>

                <TextBlock Grid.Column="2"
                           Text="ToDoDo"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource IconButtonStyle}" Click="SidebarToggleButton_Click" ToolTip="그룹 보기/숨기기">
                        <TextBlock Text="☰" FontSize="16" FontWeight="SemiBold"/>
                    </Button>
                    <Button x:Name="SettingsToggleButton" Style="{StaticResource IconButtonStyle}" Click="SettingsButton_Click" ToolTip="설정">
                        <TextBlock Text="⚙" FontSize="15"/>
                    </Button>
                    <Button x:Name="HeaderPinButton" Style="{StaticResource IconButtonStyle}" Click="PinButton_Click" ToolTip="바탕화면 고정">
                        <TextBlock Text="📌" FontSize="14"/>
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" Click="MinimizeButton_Click" ToolTip="최소화">
                        <TextBlock Text="—" FontSize="16" FontWeight="Bold" Margin="0,-2,0,0"/>
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" Margin="0" Click="CloseButton_Click" ToolTip="닫기">
                        <TextBlock Text="✕" FontSize="15" FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
                    <ColumnDefinition x:Name="SidebarSpacerColumn" Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="SidebarCard"
                        Grid.Column="0"
                        Background="{StaticResource CardBrushStrong}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="16"
                        Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="그룹"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,14"/>

                        <ListBox Grid.Row="1" x:Name="GroupListBox"
                                     ItemsSource="{Binding Groups}"
                                     SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     AllowDrop="True"
                                     DragOver="GroupListBox_DragOver"
                                     Drop="GroupListBox_Drop"
                                     KeyDown="GroupListBox_KeyDown">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Margin" Value="0,0,0,10"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="SelectionBorder"
                                                            Background="Transparent"
                                                            CornerRadius="18">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="SelectionBorder" Property="Background" Value="#1D2E55"/>
                                                            <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="#8EA0FF"/>
                                                            <Setter TargetName="SelectionBorder" Property="BorderThickness" Value="1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:TaskGroup}">
                                        <Border Background="Transparent"
                                                MouseLeftButtonDown="GroupItem_MouseLeftButtonDown"
                                                PreviewMouseLeftButtonDown="GroupItem_PreviewMouseLeftButtonDown"
                                                PreviewMouseMove="GroupItem_PreviewMouseMove">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="이름 바꾸기" Click="RenameGroupMenuItem_Click"/>
                                                    <MenuItem Header="삭제" Click="DeleteGroupMenuItem_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border Style="{StaticResource GroupItemCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="38"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="34"
                                                            Height="34"
                                                            CornerRadius="12"
                                                            Background="#34435C"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center">
                                                        <Grid>
                                                            <Ellipse Width="7" Height="7" Fill="#DCE6FF" Margin="8,8,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                                            <Ellipse Width="7" Height="7" Fill="#DCE6FF" Margin="8,0,0,8" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                                                            <Rectangle Width="11" Height="2.4" Fill="#DCE6FF" RadiusX="1.2" RadiusY="1.2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,8,0"/>
                                                            <Rectangle Width="11" Height="2.4" Fill="#DCE6FF" RadiusX="1.2" RadiusY="1.2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,10"/>
                                                        </Grid>
                                                    </Border>
                                                    <Grid Grid.Column="2">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,0,8,0"
                                                                   Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource GlassTextBoxStyle}"
                                                                 FontSize="15"
                                                                 FontWeight="SemiBold"
                                                                 Padding="8,7"
                                                                 HorizontalAlignment="Stretch"
                                                                 Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                 Loaded="GroupRenameTextBox_Loaded"
                                                                 IsVisibleChanged="GroupRenameTextBox_IsVisibleChanged"
                                                                 LostFocus="GroupRenameTextBox_LostFocus"
                                                                 KeyDown="GroupRenameTextBox_KeyDown"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        <StackPanel Grid.Row="2" Margin="0,14,0,0">
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Content="새 그룹 추가" Click="AddGroupButton_Click"/>
                            <Button Style="{StaticResource SidebarActionButtonStyle}" Margin="0" Content="선택한 그룹 삭제" Click="DeleteGroupButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>


                <GridSplitter x:Name="SidebarSplitter"
                              Grid.Column="1"
                              Width="8"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext"
                              Background="Transparent"
                              ShowsPreview="True"
                              Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                              DragCompleted="SidebarSplitter_DragCompleted"/>

                <Border Grid.Column="2"
                        Background="{StaticResource CardBrushStrong}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="{Binding MainTitleText}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="28"
                                       FontWeight="Bold"/>
                            <TextBlock Text="{Binding SummaryText}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <Grid x:Name="ToolbarGrid" Grid.Row="1" Margin="0,2,0,0" Width="{Binding ElementName=QuickAddLauncherButton, Path=ActualWidth}" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="ToolbarCol0" Width="1*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition x:Name="ToolbarCol2" Width="1*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition x:Name="ToolbarCol4" Width="1*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition x:Name="ToolbarCol6" Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource ToolbarButtonStyle}" x:Name="FilterCycleButton" HorizontalAlignment="Stretch" Content="전체" Click="CycleFilterButton_Click"/>
                            <Button Grid.Column="2" Style="{StaticResource ToolbarButtonStyle}" x:Name="SortButton" HorizontalAlignment="Stretch" Content="정렬: 날짜순" Click="SortButton_Click"/>
                            <Button Grid.Column="4" Style="{StaticResource ToolbarButtonStyle}" x:Name="CompletedToggleButton" HorizontalAlignment="Stretch" Content="완료 접기" Click="ToggleCompletedDetailsButton_Click"/>
                            <Button Grid.Column="6" x:Name="DeleteSelectedButton" Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Stretch" Content="선택 삭제" Click="DeleteSelectedTodosButton_Click"/>
                        </Grid>

                        <StackPanel Grid.Row="2" Margin="0,12,0,0">
                            <Button x:Name="QuickAddLauncherButton"
                                    Style="{StaticResource ActionButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    MinWidth="0"
                                    Padding="0"
                                    Click="ShowComposerButton_Click">
                                <Grid Margin="12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="26" Height="26" CornerRadius="13" Background="#31415A" VerticalAlignment="Center">
                                        <TextBlock Text="+" FontSize="18" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="새 할 일 추가" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="14"/>
                                </Grid>
                            </Button>

                            <Border x:Name="ComposerCard" 
                                Margin="0,10,0,0"
                                Padding="14"
                                CornerRadius="18"
                                Background="#75182435"
                                BorderBrush="#52627E"
                                BorderThickness="1"
                                Visibility="{Binding IsComposerVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <TextBox x:Name="ComposerTitleTextBox"
                                             Style="{StaticResource GlassTextBoxStyle}"
                                             Text="{Binding DraftTitle, UpdateSourceTrigger=PropertyChanged}"
                                             KeyDown="ComposerTitleTextBox_KeyDown"/>
                                    <TextBlock Text="할 일을 입력하세요"
                                               Foreground="#7E8AA5"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="18,1,0,0"
                                              >
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDraftTitleEmpty}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=ComposerTitleTextBox}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ToggleButton Grid.Row="0" Grid.Column="0"
                                                  Style="{StaticResource ToggleChipButtonStyle}"
                                                  Content="기한 설정"
                                                  IsChecked="{Binding DraftUseDueDate}"
                                                  Margin="0,0,8,8"/>
                                    <Button x:Name="DueDateButton"
                                            Grid.Row="0" Grid.Column="1"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="{Binding DraftDueDateText}"
                                            Margin="0,0,8,8"
                                            Click="DueDateButton_Click"
                                            IsEnabled="{Binding DraftUseDueDate}"/>
                                    <Button Grid.Row="0" Grid.Column="2"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="{Binding DraftPriorityText}"
                                            Margin="0,0,8,8"
                                            Click="DraftPriorityButton_Click"/>
                                    <Button Grid.Row="0" Grid.Column="3"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Margin="0,0,0,8"
                                            Content="{Binding DraftRepeatText}"
                                            Click="DraftRepeatButton_Click"/>

                                    <Grid Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Right" Height="38">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Margin="0"
                                                Height="38"
                                                MinWidth="86"
                                                VerticalAlignment="Top"
                                                Content="취소"
                                                Click="CancelComposerButton_Click"/>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource PrimaryActionButtonStyle}"
                                                Margin="0"
                                                Height="38"
                                                MinWidth="86"
                                                VerticalAlignment="Top"
                                                Content="저장"
                                                Click="SaveComposerButton_Click"/>
                                    </Grid>
                                </Grid>

                                <Popup x:Name="DueDatePopup"
                                       PlacementTarget="{Binding ElementName=DueDateButton}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade">
                                    <Border Background="#E9202D41"
                                            BorderBrush="#5A6C8C"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="12">
                                        <Calendar x:Name="DueDateCalendar"
                                                  SelectedDatesChanged="DueDateCalendar_SelectedDatesChanged"
                                                  Background="#F5F8FE"
                                                  Foreground="#1E2A3F"
                                                  BorderBrush="#C7D3EA"/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        </StackPanel>

                        <Grid x:Name="SelectionHostGrid" Grid.Row="4">
                            <ListBox x:Name="ActiveTodoListBox"
                                     ItemsSource="{Binding VisibleTodos}"
                                     SelectionMode="Extended"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     PreviewMouseLeftButtonDown="ActiveTodoListBox_PreviewMouseLeftButtonDown"
                                     PreviewMouseMove="ActiveTodoListBox_PreviewMouseMove"
                                     PreviewMouseLeftButtonUp="ActiveTodoListBox_PreviewMouseLeftButtonUp"
                                     DragOver="ActiveTodoListBox_DragOver"
                                     Drop="ActiveTodoListBox_Drop"
                                     AllowDrop="True">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Margin" Value="0,0,0,10"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="SelectionBorder" Background="Transparent" CornerRadius="18">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="#8EA0FF"/>
                                                            <Setter TargetName="SelectionBorder" Property="BorderThickness" Value="1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:TodoItem}">
                                        <Border Background="#62182435"
                                                BorderBrush="#43536E"
                                                BorderThickness="1"
                                                CornerRadius="18"
                                                Padding="14"
                                                MouseLeftButtonDown="TodoCard_MouseLeftButtonDown">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#62182435"/>
                                                    <Setter Property="BorderBrush" Value="#43536E"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompletingFeedback}" Value="True">
                                                            <Setter Property="Background" Value="#7A2B476F"/>
                                                            <Setter Property="BorderBrush" Value="#9FB2FF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="삭제" Click="DeleteTodoMenuItem_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Text}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                                        <Setter Property="Foreground" Value="#A2AECB"/>
                                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <Border Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                                            Padding="0"
                                                            CornerRadius="16"
                                                            BorderBrush="#52627E"
                                                            BorderThickness="1"
                                                            Margin="0,6,0,0">
                                                        <Grid Margin="14">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="12"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="12"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBox Grid.Row="0"
                                                                     Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                                                                     Style="{StaticResource GlassTextBoxStyle}"
                                                                     FontSize="15"
                                                                     Loaded="InlineEditTextBox_Loaded"
                                                                     KeyDown="InlineEditTextBox_KeyDown"/>
                                                            <Grid Grid.Row="2" VerticalAlignment="Center">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="8"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="8"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="8"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <ToggleButton Grid.Column="0"
                                                                              Style="{StaticResource ToggleChipButtonStyle}"
                                                                              IsChecked="{Binding EditUseDueDate, UpdateSourceTrigger=PropertyChanged}"
                                                                              Content="기한 설정"
                                                                              Margin="0"/>
                                                                <Button Grid.Column="2" Style="{StaticResource ActionButtonStyle}"
                                                                        MinWidth="0"
                                                                        Content="{Binding EditDueText}"
                                                                        Margin="0"
                                                                        IsEnabled="{Binding EditUseDueDate}"
                                                                        Click="InlineDueDateButton_Click"/>
                                                                <Button Grid.Column="4" Style="{StaticResource ActionButtonStyle}"
                                                                        MinWidth="0"
                                                                        Content="{Binding EditPriorityText}"
                                                                        Margin="0"
                                                                        Click="CycleInlinePriorityButton_Click"/>
                                                                <Button Grid.Column="6" Style="{StaticResource ActionButtonStyle}"
                                                                        MinWidth="0"
                                                                        Content="{Binding EditRepeatText}"
                                                                        Margin="0"
                                                                        Click="CycleInlineRepeatButton_Click"/>
                                                            </Grid>
                                                            <Grid Grid.Row="4" Margin="0,10,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="110"/>
                                                                    <ColumnDefinition Width="12"/>
                                                                    <ColumnDefinition Width="110"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Button Grid.Column="1" Style="{StaticResource ActionButtonStyle}" Height="38" MinWidth="0" Content="취소" Margin="0" Click="CancelInlineEditButton_Click"/>
                                                                <Button Grid.Column="3" Style="{StaticResource PrimaryActionButtonStyle}" Height="38" MinWidth="0" Content="저장" Margin="0" Click="SaveInlineEditButton_Click"/>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>

                                                    <WrapPanel Margin="0,10,0,0"
                                                              Visibility="{Binding ShowMeta, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Border Style="{StaticResource InfoChipStyle}">
                                                            <TextBlock Text="{Binding PriorityText}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <Border Style="{StaticResource InfoChipStyle}" Visibility="{Binding HasDueDate, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding DueText}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                                                        </Border>
                                                        <Border Style="{StaticResource InfoChipStyle}" Visibility="{Binding HasRepeat, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding RepeatText}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </WrapPanel>
                                                    <WrapPanel Margin="0,10,0,0">
                                                        <WrapPanel.Style>
                                                            <Style TargetType="WrapPanel">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsDone}" Value="True"/>
                                                                            <Condition Binding="{Binding AreCompletedDetailsCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </WrapPanel.Style>
                                                        <Border Style="{StaticResource InfoChipStyle}">
                                                            <TextBlock Text="완료" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </WrapPanel>
                                                </StackPanel>

                                                <Grid Grid.Column="1" VerticalAlignment="Top">
                                                    <Grid.Resources>
                                                        <Style x:Key="InlineActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                            <Setter Property="MinWidth" Value="70"/>
                                                            <Setter Property="Height" Value="34"/>
                                                            <Setter Property="Padding" Value="12,0"/>
                                                            <Setter Property="Margin" Value="0"/>
                                                        </Style>
                                                    </Grid.Resources>
                                                    <StackPanel>
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <Button Margin="0,0,0,8" Content="수정" Click="EditTodoButton_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource InlineActionButtonStyle}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding IsDone}" Value="True"/>
                                                                                <Condition Binding="{Binding AreCompletedDetailsCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </MultiDataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                        <Button Style="{StaticResource InlineActionButtonStyle}" Content="{Binding CompleteActionText}" Click="CompleteTodoButton_Click"/>
                                                    </StackPanel>
                                                </Grid>

                                                <TextBlock Grid.Column="3" Text="⋮⋮" Foreground="#95A3C4" FontSize="20" Margin="0,0,0,0" VerticalAlignment="Center" Cursor="SizeAll" ToolTip="드래그로 순서를 바꿀 수 있습니다." Tag="DragHandle" PreviewMouseLeftButtonDown="TodoDragHandle_PreviewMouseLeftButtonDown" PreviewMouseMove="TodoDragHandle_PreviewMouseMove"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

<Border x:Name="EmptyPlaceholderCard" Visibility="Collapsed"/>

                            <Canvas x:Name="SelectionOverlayCanvas"
                                    IsHitTestVisible="False"
                                    Panel.ZIndex="35">
                                <Rectangle x:Name="SelectionRubberBand"
                                           Visibility="Collapsed"
                                           RadiusX="10"
                                           RadiusY="10"
                                           Stroke="#8EA0FF"
                                           StrokeThickness="1.2"
                                           Fill="#2B7287FF"/>
                            </Canvas>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
            

<Grid x:Name="DeleteConfirmOverlay"
                  Grid.RowSpan="3"
                  Panel.ZIndex="50"
                  Background="#8606111D"
                  Visibility="{Binding IsDeleteOverlayVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Width="380"
                        Padding="22"
                        CornerRadius="22"
                        Background="#E31B2637"
                        BorderBrush="#647A9C"
                        BorderThickness="1.2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="그룹 삭제"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding DeleteOverlayMessage}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,18"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ActionButtonStyle}" MinWidth="88" IsCancel="True" Content="취소" Click="CancelDeleteOverlayButton_Click"/>
                            <Button x:Name="ConfirmDeleteButton" Style="{StaticResource PrimaryActionButtonStyle}" MinWidth="88" IsDefault="True" Content="삭제" Click="ConfirmDeleteOverlayButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>


            <Popup x:Name="InsertionPreviewPopup"
                   Grid.RowSpan="3"
                   Panel.ZIndex="58"
                   PlacementTarget="{Binding ElementName=RootChrome}"
                   Placement="RelativePoint"
                   AllowsTransparency="True"
                   PopupAnimation="None"
                   StaysOpen="True"
                   IsHitTestVisible="False">
                <Grid x:Name="InsertionPreviewMarker"
                      Width="240"
                      Height="6"
                      Opacity="0.72">
                    <Border Height="2"
                            VerticalAlignment="Center"
                            CornerRadius="1"
                            Background="#A7C9FF"/>
                </Grid>
            </Popup>

            <Popup x:Name="DragPreviewPopup"
                   Grid.RowSpan="3"
                   Panel.ZIndex="60"
                   PlacementTarget="{Binding ElementName=RootChrome}"
                   Placement="RelativePoint"
                   AllowsTransparency="True"
                   PopupAnimation="None"
                   StaysOpen="True"
                   IsHitTestVisible="False">
                <Border x:Name="DragPreviewCard"
                        Width="300"
                        Height="98"
                        Padding="14"
                        CornerRadius="16"
                        Background="#EE223551"
                        BorderBrush="#B7C6FF"
                        BorderThickness="1.4"
                        Opacity="0.96">
                    <StackPanel>
                        <TextBlock x:Name="DragPreviewTitleText"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="DragPreviewMetaText"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12.5"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Popup>
            <Border x:Name="SettingsPanel"
                    Grid.RowSpan="3"
                    Panel.ZIndex="40"
                    Width="280"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,54,0,0"
                    Padding="16"
                    CornerRadius="20"
                    Background="#E51B2637"
                    BorderBrush="#556983"
                    BorderThickness="1"
                    Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="설정"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,14"/>
                    <Button x:Name="SettingsPinButton" Style="{StaticResource ActionButtonStyle}" Content="바탕화면 고정" Click="PinButton_Click" Margin="0,0,0,10"/>
                    <Button Style="{StaticResource ActionButtonStyle}" Content="백업 내보내기" Click="ExportBackupButton_Click" Margin="0,0,0,10"/>
                    <Button Style="{StaticResource ActionButtonStyle}" Content="백업 가져오기" Click="ImportBackupButton_Click" Margin="0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

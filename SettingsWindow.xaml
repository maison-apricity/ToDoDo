<Window x:Class="ToDoDo.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ToDoDo 설정"
        Width="460"
        Height="720"
        MinWidth="420"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground="#F4F7FF"
        FontFamily="{DynamicResource AppFontFamily}">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#162338"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#43536E"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#AEBAD2"/>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#263246"/>
            <Setter Property="BorderBrush" Value="#42526C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2F4058"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6D84A7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#24324A"/>
            <Setter Property="Foreground" Value="#F4F7FF"/>
            <Setter Property="BorderBrush" Value="#556983"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2F4058"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6D84A7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CompactButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>
    </Window.Resources>
    <Border Background="#E5121C2B" BorderBrush="#4D5F7C" BorderThickness="1.2" CornerRadius="22" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1A2638" BorderBrush="#445673" BorderThickness="1" CornerRadius="16" Padding="12,10">
                <Grid MouseLeftButtonDown="HeaderDragArea_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="34" Height="34" CornerRadius="10" Background="#0D1726" BorderBrush="#4F6488" BorderThickness="1" Padding="5">
                        <Image Source="{Binding HeaderIconSource}" Stretch="Uniform" RenderOptions.BitmapScalingMode="Fant" SnapsToDevicePixels="True" UseLayoutRounding="True"/>
                    </Border>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="설정" FontSize="19" FontWeight="Bold" LineStackingStrategy="BlockLineHeight" LineHeight="24" Margin="0,1,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="3" Style="{StaticResource IconButtonStyle}" Click="CloseButton_Click">
                        <Grid Width="14" Height="14">
                            <Rectangle Width="16" Height="1.8" Fill="#F4F7FF" RadiusX="0.9" RadiusY="0.9" RenderTransformOrigin="0.5,0.5"><Rectangle.RenderTransform><RotateTransform Angle="45"/></Rectangle.RenderTransform></Rectangle>
                            <Rectangle Width="16" Height="1.8" Fill="#F4F7FF" RadiusX="0.9" RadiusY="0.9" RenderTransformOrigin="0.5,0.5"><Rectangle.RenderTransform><RotateTransform Angle="-45"/></Rectangle.RenderTransform></Rectangle>
                        </Grid>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,6,0">
                    <TextBlock Text="창 / 트레이" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12.5" Margin="0,0,0,8"/>
                    <Button Style="{StaticResource ActionButtonStyle}" Content="바탕화면 고정 켜기/끄기" Click="PinButton_Click"/>
                    <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding CloseBehaviorSettingText}" Click="ToggleCloseBehaviorButton_Click"/>
                    <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding StartMinimizedSettingText}" Click="ToggleStartMinimizedButton_Click" Margin="0,0,0,16"/>

                    <TextBlock Text="새 할 일 기본값" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12.5" Margin="0,0,0,8"/>
                    <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding DefaultPrioritySettingText}" Click="CycleDefaultPriorityButton_Click"/>
                    <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding DefaultRepeatSettingText}" Click="CycleDefaultRepeatButton_Click"/>
                    <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding DefaultDueDateSettingText}" Click="ToggleDefaultDueDateButton_Click" Margin="0,0,0,16"/>

                    <TextBlock Text="완료 / 보관" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12.5" Margin="0,0,0,8"/>
                    <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding AutoArchiveSettingText}" Click="CycleAutoArchiveButton_Click"/>
                    <Button Style="{StaticResource ActionButtonStyle}" Content="{Binding CompletedStrikeThroughSettingText}" Click="ToggleCompletedStrikeThroughButton_Click"/>
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="{Binding ArchivedSummaryText}" FontSize="13.5" FontWeight="SemiBold"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource CompactButtonStyle}" Content="보관함 열기" Margin="0" HorizontalAlignment="Stretch" Click="OpenArchiveButton_Click"/>
                                <Button Grid.Column="2" Style="{StaticResource CompactButtonStyle}" Content="보관 모두 복원" Margin="0" HorizontalAlignment="Stretch" Click="RestoreArchivedButton_Click"/>
                                <Button Grid.Column="4" Style="{StaticResource CompactButtonStyle}" Content="보관 모두 삭제" Margin="0" HorizontalAlignment="Stretch" Click="DeleteArchivedButton_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="백업" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12.5" Margin="0,0,0,8"/>
                    <Button Style="{StaticResource ActionButtonStyle}" Content="백업 내보내기" Click="ExportBackupButton_Click"/>
                    <Button Style="{StaticResource ActionButtonStyle}" Content="백업 가져오기" Click="ImportBackupButton_Click" Margin="0,0,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Style="{StaticResource CompactButtonStyle}" Content="닫기" Margin="0" Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
